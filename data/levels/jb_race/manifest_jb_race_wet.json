{
  "id": "jb_race_wet",
  "title": "JB wet",
  "required": {
    "fixed": "(%user_count <= %max_users)",
    "dynamic": "(%selected_game_mode in %game_modes)"
  },
  "on_init": {
    "declare_macro": "remote.level.load_jb_race_wet",
    "content": {
      "call": "load_scene",
      "arguments": {
        "filename": "file://$__DIR__/manifest_jb_race_wet.json"
      }
    }
  },
  "on_execute": [
    {
      "call": "globals",
      "arguments": {
        "loaded_level_id": "jb_race_wet",
        "minimap_file": null
      }
    },
    {"include": "osm_resource_jb_race_open_alpha_wet.scn.json"},
    {"include": "scene_jb_race.scn.json"}
  ],
  "on_before_select": {
    "call": "globals",
    "arguments": {
      "selected_level_id": "jb_race_wet",
      "level_icon_file": "file://levels/jb_race/icon.png"
    }
  },
  "database": {
    "max_users": 1,
    "0": {
      "car_node_position": [
        "1.008363134939195760e+01_deg",
        "4.911385574724339875e+01_deg",
        "4.46791362989359e+1"],
      "car_node_angles": [0, 140, 0]
    },
    "if_raceway_circular": false,
    "game_modes": ["rally"]
  }
}
