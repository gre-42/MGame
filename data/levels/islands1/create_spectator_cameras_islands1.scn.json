{
  "declare_macro": "create_spectator_cameras",
  "content": [
    {
      "playback": "create_spectator_camera",
      "arguments": {
        "node_name": "spectator_node_$user_name",
        "position": ["'-122.471_deg'", "'37.8508_deg'", "'111.802'"],
        "rotation": [25, 100, 0]
      }
    },
    {
      "call": "set_camera_cycle",
      "context": "primary_scene_$full_user_name",
      "arguments": {
        "name": "spectator",
        "cameras": ["spectator_node_$user_name"]
      }
    }
  ]
}
