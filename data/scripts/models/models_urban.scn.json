              "fog_ambient": "%fog_ambient"
            },
            "physics_material": "attr_visible"
          }
        }
      },
      {
        "call": "render_resource_to_textures",
        "arguments": {
          "resource": "%name",
          "color_texture_name": "$name-_billboard",
          "ortho_camera_config": {
            "near_plane": -2,
            "far_plane": 2,
            "left_plane": -1.5,
            "right_plane": 1.5,
            "bottom_plane": 0,
            "top_plane": 6
          },
          "texture_size": [1024, 1024],
          "nsamples_msaa": 4,
          "dpi": 96
        }
      }
    ]
  },
