{
  "declare_macro": "scene_racing_setup_new_round",
  "content": [
    {
      "required": "(%remote_role != 'client')",
      "call": "globals",
      "arguments": {
        "loaded_game_mode": "%selected_game_mode",
        "loaded_time_of_day": "%selected_time_of_day",
        "loaded_race_restrictions": "%selected_race_restrictions",
        "loaded_race_session": "%selected_race_session",
        "loaded_race_laps": "%selected_race_laps"
      }
    },
    {
      "required": "(%remote_role != 'client')",
      "call": "reset_countdown_start",
      "arguments": {
        "duration": 5
      }
    },
    {
      "playback": "_setup_new_round",
      "context": "primary_scene"
    },
    {
      "exclude": ["%if_spectator_mode", "%if_spectator_mode_old"],
      "context": "primary_scene",
      "execute": [
        {
          "call": "for_each_user",
          "arguments": {
            "content": [
              {
                "call": "set_camera_cycle",
                "context": "primary_scene_$full_user_name",
                "arguments": {
                  "name": "spectator",
                  "cameras": []
                }
              },
              {
                "call": "delete_root_nodes",
                "arguments": {
                  "regex": "'^spectator_node.*$'"
                }
              },
              {
                "required": "%if_spectator_mode",
                "playback": "create_spectator_cameras"
              }
            ]
          }
        },
        {
          "call": "globals",
          "arguments": { "if_spectator_mode_old": "%if_spectator_mode" }
        }
      ]
    }
  ]
}
