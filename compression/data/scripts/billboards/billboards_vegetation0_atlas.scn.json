[
  {
    "call": "add_texture_descriptor",
    "arguments": {
      "name": "bark",
      "color": "file://textures/proctree/bark.jpg",
      "color_mode": "rgb",
      "anisotropic_filtering_level": 16
    }
  },
  {
    "call": "add_texture_descriptor",
    "arguments": {
      "name": "twig_g",
      "color": "file://textures/proctree/twig_g.png",
      "color_mode": "rgba",
      "anisotropic_filtering_level": 16
    }
  },
  {
    "declare_macro": "_generate_proctree_imposter",
    "content": [
      {
        "call": "obj_resource",
        "arguments": {
          "name": "%name",
          "filename": "file://models/$name.proctree.json",
          "config": {
            "position": [0, 0, 0],
            "rotation": [0, 0, 0],
            "scale": [1, 1, 1],
            "center_distances": [0, "inf"],
            "blend_mode": "continuous",
            "alpha_distances": [0, 0, "inf", "inf"],
            "occluded_pass": "none",
            "occluder_pass": "none",
            "aggregate_mode": "none",
            "transformation_mode": "all",
            "emissive_factor": "%default_emissive_factor",
            "ambient_factor": "%default_ambient_factor",
            "diffuse_factor": "%default_diffuse_factor",
            "specular_factor": "%default_specular_factor",
            "shading": {
              "fog_distances": "%fog_distances",
              "fog_ambient": "%fog_ambient"
            }
          }
        }
      },
      {
        "call": "render_resource_to_textures",
        "arguments": {
          "resource": "%name",
          "color_texture_name": "%name",
          "ortho_camera_config": {
            "near_plane": -10,
            "far_plane": 10,
            "left_plane": -5,
            "right_plane": 5,
            "bottom_plane": -2,
            "top_plane": 8
          },
          "texture_size": [1024, 1024],
          "nsamples_msaa": 4,
          "dpi": 96
        }
      }
    ]
  },
  { "playback": "_generate_proctree_imposter", "let": { "name": "proctree/one_24/tree-1-5" } },
  { "playback": "_generate_proctree_imposter", "let": { "name": "proctree/one_24/tree-2-5" } },
  { "playback": "_generate_proctree_imposter", "let": { "name": "proctree/one/tree-3-5" } },
  { "playback": "_generate_proctree_imposter", "let": { "name": "proctree/one/tree-4-5" } },
  { "playback": "_generate_proctree_imposter", "let": { "name": "proctree/one_large/tree-1-10" } },
  { "playback": "_generate_proctree_imposter", "let": { "name": "proctree/one_large/tree-2-10" } },
  {
    "call": "add_texture_atlas_gpu",
    "arguments": {
      "name": "vegetation0",
      "width": 4096,
      "height": 2048,
      "color_mode": "rgba",
      "wrap_mode_s": "clamp_to_edge",
      "wrap_mode_t": "clamp_to_edge",
      "depth_interpolation": "nearest",
      "mipmap_mode": "with_mipmaps",
      "mip_level_count": 8,
      "anisotropic_filtering_level": 16,
      "images": [[
        {"left":    0, "bottom":    0, "width": 1024, "height": 1024, "texture": "#proctree/one_24/tree-1-5"},
        {"left": 1024, "bottom":    0, "width": 1024, "height": 1024, "texture": "#proctree/one_24/tree-2-5"},
        {"left": 2048, "bottom":    0, "width": 1024, "height": 1024, "texture": "#proctree/one/tree-3-5"},
        {"left":    0, "bottom": 1024, "width": 1024, "height": 1024, "texture": "#proctree/one/tree-4-5"},
        {"left": 1024, "bottom": 1024, "width": 1024, "height": 1024, "texture": "#proctree/one_large/tree-1-10"},
        {"left": 2048, "bottom": 1024, "width": 1024, "height": 1024, "texture": "#proctree/one_large/tree-2-10"}
      ]]
    }
  },
  {
    "exclude": "%true",
    "call": "save_texture_array_png",
    "arguments": {
      "name": "#vegetation0",
      "filename_prefix": "/tmp/vegetation0_",
      "color_mode": "rgba"
    }
  },
  {
    "call": "add_texture_descriptor",
    "arguments": {
      "name": "vegetation0",
      "color": "#vegetation0",
      "add_colormap": false
    }
  },
  {
    "call": "square_resource",
    "arguments": {
      "name": "vegetation0",
      "texture_filename": "#vegetation0",
      "min": [-0.5, 0],
      "max": [0.5, 1],
      "occluded_pass": "lightmap_blobs",
      "occluder_pass": "lightmap_black_global_and_local",
      "ambient": [1, 1, 1],
      "blend_mode": "semi_continuous_02",
      "alpha_distances": [0, 0, "inf", "inf"],
      "cull_faces": true,
      "aggregate_mode": "instances_sorted",
      "transformation_mode": "position_lookat",
      "fog_distances": "%fog_distances",
      "fog_ambient": "%fog_ambient",
      "billboards": [
        {"uv_scale": [0.25 , 0.5 ], "uv_offset":[0    , 0  ], "vertex_scale": [10  ,10  , 1], "alpha_distances": [0, 0, 450, 600], "max_center_distance": 750, "occluder_pass": "lightmap_black_global_and_local"},
        {"uv_scale": [0.25 , 0.5 ], "uv_offset":[0.25 , 0  ], "vertex_scale": [10  ,10  , 1], "alpha_distances": [0, 0, 450, 600], "max_center_distance": 750, "occluder_pass": "lightmap_black_global_and_local"},
        {"uv_scale": [0.25 , 0.5 ], "uv_offset":[0.5  , 0  ], "vertex_scale": [10  ,10  , 1], "alpha_distances": [0, 0, 450, 600], "max_center_distance": 750, "occluder_pass": "lightmap_black_global_and_local"},
        {"uv_scale": [0.25 , 0.5 ], "uv_offset":[0    , 0.5], "vertex_scale": [10  ,10  , 1], "alpha_distances": [0, 0, 450, 600], "max_center_distance": 750, "occluder_pass": "lightmap_black_global_and_local"},
        {"uv_scale": [0.25 , 0.5 ], "uv_offset":[0.25 , 0.5], "vertex_scale": [15  ,15  , 1], "alpha_distances": [0, 0, 450, 600], "max_center_distance": 750, "occluder_pass": "lightmap_black_global_and_local"},
        {"uv_scale": [0.25 , 0.5 ], "uv_offset":[0.5  , 0.5], "vertex_scale": [15  ,15  , 1], "alpha_distances": [0, 0, 450, 600], "max_center_distance": 750, "occluder_pass": "lightmap_black_global_and_local"}
      ]
    }
  }
]
