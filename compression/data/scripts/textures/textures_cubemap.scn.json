[
  {
    "declare_macro": "_lighten_skybox",
    "content": {
      "call": "add_texture_descriptor",
      "arguments": {
        "name": "%name",
        "color": "%filename",
        "color_mode": "rgb",
        "anisotropic_filtering_level": 0,
        "# lighten": [0.4, 0.4, 0.4],
        "times": 1.6,
        "plus": -0.1,
        "desaturate": 1,
        "desaturation_exponent": 0.5,
        "add_aliases": false
      }
    }
  },
  {
    "declare_macro": "_desaturate_skybox",
    "content": {
      "call": "add_texture_descriptor",
      "arguments": {
        "name": "%name",
        "color": "$prefix.luma.png",
        "chrominance": "$prefix.chrominance.png",
        "color_mode": "rgb",
        "anisotropic_filtering_level": 0,
        "desaturate": 0.5,
        "add_aliases": false
      }
    }
  },
  {
